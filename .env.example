# ============================================================
# Leitura Nova — Variáveis de Ambiente
# ============================================================
# Copie este arquivo para .env.local (dev) ou configure
# no painel da Vercel (produção).
#
# IMPORTANTE: tenha projetos Supabase separados para dev e prod.
# ============================================================

# ------ Site ------

# URL pública do site (usada em SEO, sitemap, robots e Open Graph).
# Dev: http://localhost:3000
# Prod: https://leituranova.com.br (ou URL da Vercel)
NEXT_PUBLIC_SITE_URL=https://leituranova.com.br

# ------ Supabase (público — exposto no client) ------

# URL do projeto Supabase (encontre em: Settings > API)
# Dev: URL do projeto de desenvolvimento
# Prod: URL do projeto de produção
NEXT_PUBLIC_SUPABASE_URL=https://SEU-PROJETO.supabase.co

# Chave anon/pública (encontre em: Settings > API > anon key)
# Segura para expor no client — RLS protege os dados
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ------ Supabase (privado — NÃO expor no client) ------

# Chave service_role (encontre em: Settings > API > service_role key)
# Usada APENAS no server (API Routes, Server Actions)
# Tem acesso total, ignora RLS — NUNCA prefixe com NEXT_PUBLIC_
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
